  "keyFeatures": [
    "Ultra-low latency WebRTC streaming (~0.5s)",
    "Multi-protocol support (WebRTC, SRT, RTMP, RTSP, HLS, CMAF)",
    "Adaptive bitrate (ABR) streaming and transcoding",
    "Horizontal scaling with clustering support",
    "IP camera and ONVIF integration",
    "Recording to MP4, WebM with cloud storage (S3, GCP)",
    "Token-based authentication and JWT security",
    "Real-time analytics and viewer statistics",
    "Push notifications (Firebase, APNs)",
    "Enterprise features: SRT ingest, advanced encoding, auto-scaling"
  ],
  "publicApiSurface": [
    "/rest/v2/broadcasts - Broadcast management API",
    "/rest/v2/vod - Video on demand API",
    "/rest/v2/cluster - Cluster management API",
    "/rest/v2/push-notifications - Push notification API",
    "BroadcastRestService - Main REST service for streams",
    "VoDRestService - Video on demand service",
    "AntMediaApplicationAdapter - Core application adapter",
    "IWebRTCAdaptor - WebRTC integration interface",
    "MuxAdaptor - Stream muxing and adaptive bitrate",
    "HLSMuxer - HLS/CMAF output",
    "StreamFetcher - External stream ingestion",
    "ClusterNode - Clustering and load balancing",
    "TokenFilterManager - Security and access control",
    "StorageClient - Cloud storage integration"
  ]
